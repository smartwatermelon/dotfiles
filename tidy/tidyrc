// HTML Tidy configuration for modern HTML5
// Allows modern attributes like 'decoding', 'loading', etc.

// Set doctype to HTML5
doctype: html5

// Don't drop or warn about proprietary attributes (allows modern HTML5 attrs)
drop-proprietary-attributes: no
warn-proprietary-attributes: no

// Show only errors, not warnings
show-warnings: no

// Quiet mode
quiet: yes
